  <div class="work-grid">
    <div class="work-item">
      <div class="work-bg" style="background:linear-gradient(135deg,#1a1814,#3d2e5a,#1a1814);height:100%"></div>
      <div class="work-tag">Брендинг</div>
      <div class="work-overlay">
        <div class="work-info">
          <div class="work-name">Nexus Finance — Айдентика</div>
          <div class="work-type">Логотип · Brand book · Носители</div>
