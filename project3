      </div>
    </div>
    <div class="work-item">
      <div class="work-bg" style="background:linear-gradient(135deg,#0d2818,#1a4d2e);height:100%"></div>
      <div class="work-tag">Веб</div>
      <div class="work-overlay">
        <div class="work-info">
          <div class="work-name">Eco Market — Сайт</div>
          <div class="work-type">UI/UX · Адаптив · Анимации</div>
        </div>
      </div>
    </div>
    <div class="work-item">
      <div class="work-bg" style="background:linear-gradient(135deg,#2d1010,#6b2020);height:100%"></div>
      <div class="work-tag">UI/UX</div>
      <div class="work-overlay">
        <div class="work-info">
          <div class="work-name">Pulse App — Интерфейс</div>
          <div class="work-type">Мобильное приложение</div>
        </div>
      </div>
    </div>
    <div class="work-item">
      <div class="work-bg" style="background:linear-gradient(135deg,#1a1430,#2d2260);height:100%"></div>
      <div class="work-tag">Брендинг</div>
      <div class="work-overlay">
        <div class="work-info">
          <div class="work-name">Luna Café — Айдентика</div>
          <div class="work-type">Логотип · Упаковка · Меню</div>
        </div>
      </div>
    </div>
    <div class="work-item">
      <div class="work-bg" style="background:linear-gradient(135deg,#0d1a14,#1a3d2a);height:100%"></div>
      <div class="work-tag">Лендинг</div>
      <div class="work-overlay">
        <div class="work-info">
          <div class="work-name">TechStart — Лендинг</div>
          <div class="work-type">Разработка + Дизайн</div>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="services" id="services">
  <h2 class="work-title" style="color:#fff;position:relative;z-index:1">Чем я<br/>занимаюсь</h2>
  <div class="services-list">
    <div class="service-row">
      <div class="sr-left">
        <div class="sr-num">01</div>
        <div class="sr-name">Брендинг и айдентика</div>
      </div>
      <div class="sr-right">
