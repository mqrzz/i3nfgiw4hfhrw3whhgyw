<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Алина Краснова — Дизайнер</title>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=Inter:wght@300;400;500&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #f2f0ed;
      --bg2: #e8e4df;
      --ink: #1a1814;
      --accent: #ff4d2e;
      --accent2: #ff7a5c;
      --muted: #8a8680;
      --border: rgba(26,24,20,0.1);
      --card: #ffffff;
    }

    html { scroll-behavior: smooth; }

    body {
      background: var(--bg);
      color: var(--ink);
      font-family: 'Inter', sans-serif;
      font-weight: 300;
      line-height: 1.65;
      overflow-x: hidden;
      cursor: none;
    }

    /* CURSOR */
    .cursor {
      position: fixed;
      width: 12px; height: 12px;
      background: var(--accent);
      border-radius: 50%;
      pointer-events: none;
      z-index: 9999;
      transition: transform .15s, width .2s, height .2s;
      transform: translate(-50%, -50%);
    }

    .cursor-ring {
      position: fixed;
      width: 40px; height: 40px;
      border: 1px solid rgba(255,77,46,0.4);
      border-radius: 50%;
      pointer-events: none;
      z-index: 9998;
      transition: transform .35s cubic-bezier(.25,.46,.45,.94), width .25s, height .25s, opacity .2s;
      transform: translate(-50%, -50%);
    }

    body:has(a:hover) .cursor { transform: translate(-50%, -50%) scale(2); }
    body:has(a:hover) .cursor-ring { width: 60px; height: 60px; opacity: .5; }

    /* BACK */
    .back-banner {
      position: fixed;
      top: 1rem; left: 1rem;
      z-index: 300;
      background: var(--ink);
      color: var(--bg);
      font-size: .65rem;
      letter-spacing: .1em;
      text-transform: uppercase;
      padding: .5rem 1rem;
      text-decoration: none;
      border-radius: 50px;
      transition: background .2s;
      display: flex;
      align-items: center;
      gap: .4rem;
    }
    .back-banner:hover { background: var(--accent); }

    .demo-badge {
      position: fixed;
      bottom: 1.5rem; right: 1.5rem;
      z-index: 300;
      background: var(--accent);
      color: #fff;
      font-size: .62rem;
      font-weight: 500;
      letter-spacing: .1em;
      text-transform: uppercase;
      padding: .45rem .9rem;
      border-radius: 50px;
    }

    /* NAV */
    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1.2rem 5vw;
      background: rgba(242,240,237,0.9);
      backdrop-filter: blur(16px);
      border-bottom: 1px solid var(--border);
    }

    .nav-logo {
      font-family: 'Syne', sans-serif;
      font-weight: 800;
      font-size: .95rem;
      letter-spacing: .04em;
      text-transform: uppercase;
      color: var(--ink);
      text-decoration: none;
    }

    .nav-links {
      display: flex;
      gap: 2rem;
      align-items: center;
    }

    .nav-links a {
      color: var(--muted);
      text-decoration: none;
      font-size: .78rem;
      transition: color .2s;
    }

    .nav-links a:hover { color: var(--ink); }

    .nav-cta {
      background: var(--accent) !important;
      color: #fff !important;
      padding: .5rem 1.3rem !important;
      border-radius: 50px !important;
      font-size: .75rem !important;
      font-weight: 500 !important;
    }

    /* HERO */
    .hero {
      min-height: 100vh;
      display: flex;
      align-items: center;
      padding: 8rem 5vw 4rem;
      position: relative;
      overflow: hidden;
    }

    .hero-bg-text {
      position: absolute;
      bottom: -4rem; right: -2rem;
      font-family: 'Syne', sans-serif;
      font-weight: 800;
      font-size: 22vw;
      color: rgba(26,24,20,0.04);
      line-height: 1;
      pointer-events: none;
      letter-spacing: -.04em;
      white-space: nowrap;
    }

    .hero-inner {
      position: relative;
      z-index: 1;
      width: 100%;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      align-items: center;
    }

    .hero-left {}

    .hero-status {
      display: inline-flex;
      align-items: center;
      gap: .5rem;
      background: rgba(255,77,46,0.08);
      border: 1px solid rgba(255,77,46,0.2);
      border-radius: 50px;
      padding: .3rem .85rem;
      font-size: .68rem;
      color: var(--accent);
      letter-spacing: .06em;
      margin-bottom: 1.8rem;
    }

    .status-dot {
      width: 5px; height: 5px;
      border-radius: 50%;
      background: var(--accent);
      animation: blink 1.5s infinite;
    }

    @keyframes blink { 0%,100%{opacity:1} 50%{opacity:.3} }

    .hero-title {
      font-family: 'Syne', sans-serif;
      font-weight: 800;
      font-size: clamp(3rem, 6vw, 5.5rem);
      line-height: 1;
      letter-spacing: -.03em;
      margin-bottom: 1.5rem;
    }

    .hero-title .line2 {
      color: transparent;
      -webkit-text-stroke: 2px var(--ink);
    }

    .hero-title .accent { color: var(--accent); }

    .hero-desc {
      color: var(--muted);
      font-size: .9rem;
      max-width: 400px;
      margin-bottom: 2.5rem;
      line-height: 1.75;
    }

    .hero-actions {
      display: flex;
      gap: .75rem;
      align-items: center;
      flex-wrap: wrap;
    }

    .btn-red {
      background: var(--accent);
      color: #fff;
      padding: .85rem 2rem;
      border-radius: 50px;
      font-size: .8rem;
      font-weight: 500;
      text-decoration: none;
      transition: background .2s, transform .15s;
      display: inline-flex;
      align-items: center;
      gap: .5rem;
      border: none;
      cursor: none;
    }

    .btn-red:hover { background: var(--accent2); transform: translateY(-2px); }

    .btn-border {
      border: 1.5px solid var(--ink);
      color: var(--ink);
      padding: .85rem 2rem;
      border-radius: 50px;
      font-size: .8rem;
      text-decoration: none;
      transition: background .2s, color .2s;
    }

    .btn-border:hover { background: var(--ink); color: var(--bg); }

    .hero-right {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: .75rem;
    }

    .hero-card {
      background: var(--card);
      border-radius: 20px;
      padding: 1.5rem;
      border: 1px solid var(--border);
      transition: transform .2s;
    }

    .hero-card:hover { transform: translateY(-4px); }
    .hero-card:nth-child(1) { grid-column: span 2; }
    .hero-card:nth-child(2) { background: var(--accent); }

    .card-label {
      font-size: .62rem;
      letter-spacing: .12em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: .5rem;
    }

    .hero-card:nth-child(2) .card-label { color: rgba(255,255,255,0.6); }

    .card-num {
      font-family: 'Syne', sans-serif;
      font-weight: 800;
      font-size: 2.5rem;
      line-height: 1;
      color: var(--ink);
    }

    .hero-card:nth-child(2) .card-num { color: #fff; }

    .card-desc {
      font-size: .75rem;
      color: var(--muted);
      margin-top: .3rem;
    }

    .hero-card:nth-child(2) .card-desc { color: rgba(255,255,255,0.7); }

    .card-big {
      display: flex;
      align-items: center;
      gap: 1.2rem;
    }

    .card-big-icon {
      width: 52px; height: 52px;
      border-radius: 14px;
      background: var(--bg);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.4rem;
      flex-shrink: 0;
    }

    /* WORK */
    .work {
      padding: 8rem 5vw;
    }

    .work-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 3rem;
      flex-wrap: wrap;
      gap: 1rem;
    }

    .work-title {
      font-family: 'Syne', sans-serif;
      font-weight: 800;
      font-size: clamp(2rem, 4vw, 3.5rem);
      letter-spacing: -.03em;
    }

    .work-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1rem;
    }

    .work-item {
      border-radius: 20px;
      overflow: hidden;
      position: relative;
      aspect-ratio: 4/3;
      cursor: none;
    }

    .work-item:first-child {
      grid-column: span 2;
      aspect-ratio: 16/9;
    }

    .work-bg {
      width: 100%; height: 100%;
      transition: transform .4s;
    }

    .work-item:hover .work-bg { transform: scale(1.04); }

    .work-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, rgba(26,24,20,0.85) 0%, transparent 60%);
      opacity: 0;
      transition: opacity .3s;
      display: flex;
      align-items: flex-end;
      padding: 1.5rem;
    }

    .work-item:hover .work-overlay { opacity: 1; }

    .work-info {}
    .work-name { font-family: 'Syne', sans-serif; font-weight: 700; font-size: 1rem; color: #fff; }
    .work-type { font-size: .72rem; color: rgba(255,255,255,0.6); margin-top: .2rem; }

    .work-tag {
      position: absolute;
      top: 1rem; left: 1rem;
      background: rgba(255,255,255,0.9);
      backdrop-filter: blur(8px);
      color: var(--ink);
      font-size: .62rem;
      font-weight: 500;
      letter-spacing: .08em;
      text-transform: uppercase;
      padding: .25rem .7rem;
      border-radius: 50px;
    }

    /* SERVICES */
    .services {
      padding: 8rem 5vw;
      background: var(--ink);
      position: relative;
      overflow: hidden;
    }

    .services::before {
      content: '';
      position: absolute;
      top: -200px; right: -200px;
      width: 600px; height: 600px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(255,77,46,0.08) 0%, transparent 70%);
    }

    .services .work-title { color: #fff; }

    .services-list {
      display: flex;
      flex-direction: column;
      margin-top: 3rem;
      position: relative;
      z-index: 1;
    }

    .service-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1.8rem 0;
      border-bottom: 1px solid rgba(255,255,255,0.07);
      gap: 2rem;
      transition: padding-left .2s;
      cursor: none;
    }

    .service-row:hover { padding-left: 1rem; }
    .service-row:first-child { border-top: 1px solid rgba(255,255,255,0.07); }

    .sr-left { display: flex; align-items: center; gap: 1.5rem; }
    .sr-num {
      font-family: 'Syne', sans-serif;
      font-size: .75rem;
      color: var(--accent);
      font-weight: 700;
      min-width: 28px;
    }
    .sr-name {
      font-family: 'Syne', sans-serif;
      font-size: clamp(1.1rem, 2vw, 1.6rem);
      font-weight: 700;
      color: #fff;
    }
    .sr-right { display: flex; align-items: center; gap: 2rem; }
    .sr-price { font-family: 'Syne', sans-serif; font-weight: 700; font-size: 1rem; color: var(--accent); white-space: nowrap; }
    .sr-arrow { color: rgba(255,255,255,0.3); font-size: 1.2rem; transition: color .2s, transform .2s; }
    .service-row:hover .sr-arrow { color: var(--accent); transform: translateX(4px); }
    .sr-tags { display: flex; gap: .4rem; flex-wrap: wrap; }
    .sr-tag {
      background: rgba(255,255,255,0.06);
      border: 1px solid rgba(255,255,255,0.1);
      color: rgba(255,255,255,0.5);
      font-size: .62rem;
      padding: .18rem .55rem;
      border-radius: 50px;
    }

    /* ABOUT */
    .about {
      padding: 8rem 5vw;
      display: grid;
      grid-template-columns: 1fr 1.2fr;
      gap: 6rem;
      align-items: center;
    }

    .about-img {
      aspect-ratio: 3/4;
      border-radius: 24px;
      background: linear-gradient(135deg, var(--bg2), var(--accent2));
      position: relative;
      overflow: hidden;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .about-img-inner {
      font-family: 'Syne', sans-serif;
      font-weight: 800;
      font-size: 8rem;
      color: rgba(255,255,255,0.15);
      line-height: 1;
    }

    .about-img-badge {
      position: absolute;
      bottom: 1.5rem; right: 1.5rem;
      background: #fff;
      border-radius: 16px;
      padding: 1rem 1.2rem;
      font-size: .75rem;
    }

    .about-img-badge strong {
      display: block;
      font-family: 'Syne', sans-serif;
      font-weight: 800;
      font-size: 1.4rem;
      color: var(--accent);
    }

    .about-eyebrow {
      font-size: .65rem;
      letter-spacing: .18em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: .8rem;
    }

    .about-title {
      font-family: 'Syne', sans-serif;
      font-weight: 800;
      font-size: clamp(2rem, 3vw, 2.8rem);
      letter-spacing: -.03em;
      line-height: 1.1;
      margin-bottom: 1.2rem;
    }

    .about-desc {
      color: var(--muted);
      font-size: .88rem;
      line-height: 1.8;
      margin-bottom: 2rem;
    }

    .about-skills {
      display: flex;
      flex-wrap: wrap;
      gap: .5rem;
      margin-bottom: 2.5rem;
    }

    .skill-tag {
      background: var(--bg2);
      border: 1px solid var(--border);
      color: var(--ink);
      font-size: .72rem;
      font-weight: 500;
      padding: .35rem .85rem;
      border-radius: 50px;
    }

    /* CONTACT */
    .contact-section {
      padding: 8rem 5vw;
      background: var(--bg2);
      text-align: center;
    }

    .contact-title {
      font-family: 'Syne', sans-serif;
      font-weight: 800;
      font-size: clamp(2.5rem, 5vw, 5rem);
      letter-spacing: -.04em;
      line-height: 1;
      margin-bottom: 1rem;
    }

    .contact-title span { color: var(--accent); }
    .contact-sub { color: var(--muted); font-size: .92rem; margin-bottom: 3rem; }

    .contact-links {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 1rem;
      flex-wrap: wrap;
    }

    .contact-link {
      display: flex;
      align-items: center;
      gap: .6rem;
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 50px;
      padding: .75rem 1.5rem;
      font-size: .82rem;
      color: var(--ink);
      text-decoration: none;
      transition: background .2s, border-color .2s, transform .15s;
    }

    .contact-link:hover { border-color: var(--accent); transform: translateY(-2px); }

    /* FOOTER */
    footer {
      padding: 2rem 5vw;
      border-top: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: space-between;
      font-size: .75rem;
      color: var(--muted);
    }

    footer a { color: var(--accent); text-decoration: none; }

    .footer-logo {
      font-family: 'Syne', sans-serif;
      font-weight: 800;
      font-size: 1rem;
      color: var(--ink);
      letter-spacing: -.01em;
    }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(24px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .hero-status { animation: fadeUp .6s .1s both; }
    .hero-title { animation: fadeUp .6s .2s both; }
    .hero-desc { animation: fadeUp .6s .3s both; }
    .hero-actions { animation: fadeUp .6s .4s both; }
    .hero-right { animation: fadeUp .6s .3s both; }

    @media (max-width: 900px) {
      .hero-inner { grid-template-columns: 1fr; }
      .hero-right { display: none; }
      .work-grid { grid-template-columns: 1fr; }
      .work-item:first-child { grid-column: span 1; aspect-ratio: 4/3; }
      .about { grid-template-columns: 1fr; }
      .about-img { aspect-ratio: 1/1; }
      .sr-tags { display: none; }
      .nav-links { display: none; }
      body { cursor: auto; }
      .cursor, .cursor-ring { display: none; }
    }
  </style>
</head>
<body>

<div class="cursor" id="cursor"></div>
<div class="cursor-ring" id="cursorRing"></div>

<a href="/" class="back-banner">← Antviz · Демо</a>
<div class="demo-badge">Демо-сайт</div>

<nav>
  <a href="#" class="nav-logo">Alina.design</a>
  <div class="nav-links">
    <a href="#work">Работы</a>
    <a href="#services">Услуги</a>
    <a href="#about">Обо мне</a>
    <a href="#contact" class="nav-cta">Написать →</a>
  </div>
</nav>

<section class="hero">
  <div class="hero-bg-text">DESIGN</div>
  <div class="hero-inner">
    <div class="hero-left">
      <div class="hero-status">
        <div class="status-dot"></div>
        Доступна для проектов
      </div>
