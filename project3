      <div class="hero-actions">
        <a href="#work" class="btn-red">Смотреть работы →</a>
        <a href="#contact" class="btn-border">Связаться</a>
      </div>
    </div>
    <div class="hero-right">
      <div class="hero-card">
        <div class="card-big">
          <div class="card-big-icon">🏆</div>
          <div>
            <div class="card-label">Достижение</div>
            <div style="font-family:'Syne',sans-serif;font-weight:700;font-size:.95rem">Awwwards Site of the Day</div>
            <div class="card-desc">Лучший сайт дня · 2023</div>
          </div>
        </div>
      </div>
      <div class="hero-card">
        <div class="card-label">Проектов</div>
        <div class="card-num">80<span style="color:var(--accent)">+</span></div>
        <div class="card-desc">Завершено</div>
      </div>
      <div class="hero-card" style="background:var(--bg2)">
        <div class="card-label">Опыт</div>
        <div class="card-num" style="font-size:2rem">6 лет</div>
        <div class="card-desc">В профессии</div>
      </div>
    </div>
  </div>
</section>

<section class="work" id="work">
  <div class="work-header">
    <h2 class="work-title">Избранные<br/>работы</h2>
    <a href="#contact" class="btn-red" style="font-size:.78rem">Обсудить проект →</a>
